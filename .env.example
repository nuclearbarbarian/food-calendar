# Copy to .env and fill in. Never commit .env.
PORT=3000

# Resend — new key, named "food-prod" in the Resend dashboard.
RESEND_API_KEY=re_xxx

# Sender address (must be on a domain verified in your Resend account).
# Parallels ChoreCal's sender.
DIGEST_FROM=food@example.com

# Recipient(s) of the morning digest and shopping-list emails. Just Parke.
DIGEST_TO=parke@example.com

# Timezone for digest timing. Fly.io runs UTC; we live in Central.
DIGEST_TZ=America/Chicago

# Database file path. Defaults to ./food.db locally, /data/food.db in production.
DB_PATH=./food.db
